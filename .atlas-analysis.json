  "keyFeatures": [
    "Complete Square API coverage with 30+ resource clients",
    "Automatic pagination with iterator support",
    "Built-in retry logic with exponential backoff",
    "Webhook signature verification",
    "Support for sandbox and production environments",
    "Type-safe request and response models",
    "Context-based timeout configuration",
    "Flexible request options and custom HTTP clients"
  ],
  "publicApiSurface": [
    "client.NewClient() - Initialize Square API client",
    "client.Payments - Payment processing operations",
    "client.Orders - Order management",
    "client.Customers - Customer management",
    "client.Catalog - Product catalog operations",
    "client.Inventory - Inventory tracking",
    "client.Invoices - Invoice management",
    "client.Subscriptions - Subscription billing",
    "client.Locations - Location management",
    "client.OAuth - OAuth authentication",
    "client.Webhooks.VerifySignature() - Webhook verification",
    "option.WithToken() - Configure API token",
    "option.WithBaseURL() - Configure environment",
    "option.WithMaxAttempts() - Configure retry behavior",
    "option.WithHTTPClient() - Custom HTTP client",
    "square.Environments.Sandbox - Sandbox environment",
    "square.Environments.Production - Production environment"
  ]
